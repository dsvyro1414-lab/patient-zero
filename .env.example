# Whoop Developer app — register at https://developer-dashboard.whoop.com
# Copy this file to .env and fill in. Never commit .env.
WHOOP_CLIENT_ID=your_client_id
WHOOP_CLIENT_SECRET=your_client_secret
WHOOP_REDIRECT_URI=http://localhost:3000/api/whoop/callback

# Where the Next.js frontend reaches the Python ML service
ML_SERVICE_URL=http://localhost:8000
