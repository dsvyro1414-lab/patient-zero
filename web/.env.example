# Copy to web/.env.local (gitignored) and fill in. Never commit real secrets.

# Anthropic API key for the "summary for your doctor" route (/api/labs-summary).
# Get one at https://console.anthropic.com/ . Without it, the labs summary shows
# a clear "AI service not configured" message; the rest of the app works.
ANTHROPIC_API_KEY=

# Optional: URL of the Python ML service (defaults to http://localhost:8000).
# ML_SERVICE_URL=
